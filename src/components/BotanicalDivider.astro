---
interface Props {
  color?: string;
  width?: number;
  ariaHidden?: boolean;
}
const { color = "currentColor", width = 96, ariaHidden = true } = Astro.props;
---

<svg
  class="botanical-divider"
  viewBox="0 0 240 32"
  width={width}
  height={(width * 32) / 240}
  fill="none"
  stroke={color}
  stroke-width="1.25"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden ? "true" : undefined}
>
  <path d="M8 16 H92" opacity="0.55" />
  <path d="M148 16 H232" opacity="0.55" />
  <!-- Leafy sprig center -->
  <path d="M120 4 Q120 16 120 28" opacity="0.85" />
  <path d="M120 10 Q112 9 106 14 Q113 16 120 14" opacity="0.85" />
  <path d="M120 14 Q128 13 134 18 Q127 20 120 18" opacity="0.85" />
  <path d="M120 19 Q113 18 108 22 Q114 24 120 22" opacity="0.85" />
  <circle cx="120" cy="6" r="1.2" fill={color} stroke="none" opacity="0.85" />
</svg>

<style>
  .botanical-divider {
    display: block;
    margin-inline: auto;
  }
</style>
