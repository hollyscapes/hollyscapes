---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import ClosingCta from "../components/ClosingCta.astro";
import { getEntry } from "astro:content";

const page = await getEntry("pages", "about");
if (!page) throw new Error("Missing pages/about.md content entry");
if (page.data.template !== "about")
  throw new Error("pages/about.md must use template: about");

const { hero, portrait, story, philosophy, closing_cta, draft } = page.data;
---

<Layout title="About" draft={draft}>
  <PageHero {...hero} />

  {/* Story — cream relief band with portrait alongside text */}
  <section class="band band--cream story">
    <div class="container story__inner">
      {portrait && (
        <figure class="story__portrait">
          <div class="story__portrait-frame">
            <img src={portrait.image} alt={portrait.alt} loading="lazy" />
          </div>
          {portrait.caption && (
            <figcaption>{portrait.caption}</figcaption>
          )}
        </figure>
      )}

      <div class="story__body">
        {story.eyebrow && <span class="eyebrow">{story.eyebrow}</span>}
        <h2>{story.heading}</h2>
        {story.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  {/* Philosophy — sage band with floating cards */}
  <section class="band band--sage philosophy">
    <div class="container philosophy__inner">
      <header class="philosophy__head">
        {philosophy.eyebrow && (
          <span class="eyebrow">{philosophy.eyebrow}</span>
        )}
        <h2>{philosophy.heading}</h2>
        {philosophy.intro && <p class="philosophy__intro">{philosophy.intro}</p>}
      </header>

      <ul class="philosophy__grid">
        {philosophy.principles.map((p, i) => (
          <li class="card philosophy-card">
            <span class="philosophy-card__num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <ClosingCta {...closing_cta} />
</Layout>

<style>
  /* Story band */
  .story__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
    gap: clamp(var(--space-6), 5vw, var(--space-8));
    align-items: start;
  }
  .story__portrait { margin: 0; }
  .story__portrait-frame {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--sage-light);
    box-shadow: var(--shadow-soft);
  }
  .story__portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .story__portrait figcaption {
    margin-top: var(--space-3);
    font-size: 0.92rem;
    color: var(--text-on-cream-muted);
    font-style: italic;
  }
  .story__body h2 { margin-top: var(--space-2); }
  .story__body p {
    margin-top: var(--space-4);
    font-size: 1.05rem;
  }

  /* Philosophy band */
  .philosophy__head {
    max-width: 38rem;
    margin-inline: auto;
    text-align: center;
    margin-bottom: var(--space-7);
    color: var(--text-on-sage);
  }
  .philosophy__head h2 { color: var(--cream-parchment); }
  .philosophy__head .eyebrow { color: var(--text-on-sage-muted); }
  .philosophy__intro {
    margin-top: var(--space-3);
    margin-inline: auto;
    color: var(--text-on-sage);
  }
  .philosophy__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .philosophy-card { position: relative; padding-top: var(--space-6); }
  .philosophy-card__num {
    position: absolute;
    top: var(--space-4);
    right: var(--space-5);
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--clay);
    letter-spacing: 0.1em;
  }
  .philosophy-card h3 { color: var(--text-on-cream); margin-bottom: var(--space-3); }
  .philosophy-card p { color: var(--text-on-cream-muted); font-size: 0.98rem; }

  @media (max-width: 820px) {
    .story__inner { grid-template-columns: 1fr; gap: var(--space-6); }
    .story__portrait { max-width: 22rem; }
    .philosophy__grid { grid-template-columns: 1fr; }
  }
</style>
